{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const p=path.join(process.cwd(),'node_modules','@types');fs.mkdirSync(p,{recursive:true});const t=path.join(p,'express');try{fs.unlinkSync(t);}catch(e){}; if(!fs.existsSync(t))fs.symlinkSync(path.join(process.cwd(),'../../node_modules/@types/express'),t);\""
  },
  "dependencies": {
    "@columbusai/db": "file:../../packages/db",
    "express": "^4.21",
    "openai": "^4",
    "pg": "^8.19.0",
    "redis": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/express": "^4.17",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "tsx": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
