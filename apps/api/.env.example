# apps/api — API service. Copy to .env and set values.
# Used when running the API alone (e.g. npm run dev) or as the api service in Docker Compose.
# When using Docker compose, the api service reads apps/web/.env—put these variables there.

# --- Server ---
PORT=4000

# --- CORS (optional; default allows http://localhost:3000 and http://127.0.0.1:3000) ---
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# --- Database (Prisma; required for /api/chat) ---
DATABASE_URL=postgresql://columbus:password@localhost:5432/columbus
# Docker: compose overrides with postgres:5432

# --- Redis (rate limiting; required for /api/chat when set) ---
REDIS_URL=redis://localhost:6379
# Docker: compose overrides with redis://redis:6379

# --- OpenAI (required for /api/chat) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_STORE=true
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Vector RAG (optional) ---
# VECTOR_DATABASE_URL=postgresql://columbus:password@localhost:5433/columbus_vectors

# --- Rate limit tuning (optional) ---
# RATE_LIMIT_SCOPE=ip
# RATE_LIMIT_MAX_REQUESTS=20
# RATE_LIMIT_WINDOW_SECONDS=300

# --- Retrieval (optional) ---
# RETRIEVAL_K=5
