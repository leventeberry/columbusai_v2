{
  "compilerOptions": {
  "target": "ES2022",
  "module": "NodeNext",
  "moduleResolution": "NodeNext",
  "lib": ["ES2022"],
  "outDir": "dist",
  "rootDir": "src",
  "baseUrl": "../..",
  "strict": true,
  "esModuleInterop": true,
  "skipLibCheck": true,
  "forceConsistentCasingInFileNames": true,
  "resolveJsonModule": true,
  "declaration": true,
  "declarationMap": true,
  "sourceMap": true,
  "types": ["node", "express"],
  "typeRoots": ["../../node_modules/@types", "node_modules/@types"],
  "isolatedModules": true,
  "incremental": true
},
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
