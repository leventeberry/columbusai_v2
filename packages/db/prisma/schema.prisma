// Multi-schema preview for Postgres.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["chat"]
}

// --- chat schema ---

model Conversation {
  id                       String    @id @default(uuid())
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  external_conversation_key String?
  messages                 Message[]

  @@map("conversations")
  @@schema("chat")
}

enum MessageRole {
  user
  assistant
  system
  developer
  tool

  @@schema("chat")
}

model Message {
  id                         String    @id @default(uuid())
  conversation_id            String
  conversation               Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  role                       MessageRole
  content                    String    @db.Text
  created_at                 DateTime  @default(now())

  // Responses API compatibility (nullable; not used in Phase 1 logic)
  openai_response_id         String?
  previous_openai_response_id String?
  store                      Boolean?
  output_items               Json?
  request_id                 String?
  model                      String?
  latency_ms                 Int?
  token_input                Int?
  token_output               Int?
  meta                       Json?

  @@index([conversation_id])
  @@map("messages")
  @@schema("chat")
}

// Vector RAG uses a separate database (VECTOR_DATABASE_URL), managed by pg client in lib/vector-db.ts — no Prisma.
