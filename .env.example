# Repo root — used by Docker Compose (e.g. POSTGRES_PASSWORD) when run from root.
# Each app has its own .env: e.g. apps/web/.env for the Next.js app.

# --- Compose: Postgres (optional; default columbus) ---
# POSTGRES_PASSWORD=columbus

# Web app env is loaded from apps/web/.env by the web service (see compose env_file).
# Create apps/web/.env from apps/web/.env.example and set OPENAI_API_KEY there.
