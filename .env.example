# Repo root — used by Docker Compose when run from repo root (e.g. make up).
# Each app has its own .env: apps/web/.env (web + api services use this in compose), apps/api/.env (API when run standalone).

# --- Traefik (required for host-based routing and TLS) ---
# DOMAIN=columbusai.tech
# ACME_EMAIL=admin@columbusai.tech

# --- Compose: Postgres password (optional; default columbus) ---
# POSTGRES_PASSWORD=columbus

# For Docker compose: create apps/web/.env from apps/web/.env.example, then add
# variables from apps/api/.env.example (at least OPENAI_API_KEY) so the api service can run.
